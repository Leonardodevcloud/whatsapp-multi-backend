# === Servidor ===
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://seu-dominio.vercel.app

# === PostgreSQL (Neon) ===
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# === Redis (Railway add-on ou Upstash) ===
REDIS_URL=redis://default:pass@host:port

# === JWT ===
JWT_SECRET=trocar-por-chave-segura-min-32-chars
JWT_REFRESH_SECRET=trocar-por-outra-chave-segura-min-32-chars

# === Cloudflare R2 (ou S3 compatível) — Fase 2 ===
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# === IA (Claude API) — Fase 3 ===
# AI_API_KEY=
